#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: ubuntu-esxi-template
    username: agent
    # Replace with a real password hash before use.
    # Example placeholder only: generate a SHA-512 hash for your local workflow.
    password: REPLACE_WITH_PASSWORD_HASH
  ssh:
    install-server: true
    allow-pw: false
    # Supply one or more local, non-committed public keys before use.
    authorized-keys:
      - REPLACE_WITH_SSH_PUBLIC_KEY
  packages:
    - openssh-server
    - open-vm-tools
  # Do not assume eth0: let the installer detect networking by default. Add a
  # MAC-address match in a local copy only after verifying the target NIC.
  late-commands:
    - curtin in-target --target=/target -- systemctl enable ssh || true
