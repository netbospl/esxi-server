# Example ESXi environment configuration.
# Copy this file to .env or configure these values in your shell/secret manager.
# Do not commit real hostnames, passwords, tokens, private IPs, or SSH key material.

ESXI_HOST=esxi.example.test
ESXI_USER=agent
# Leave blank unless a secret manager or protected local environment supplies it.
ESXI_PASS=
ESXI_SSH_KEY=$HOME/.ssh/esxi-agent
ESXI_KNOWN_HOSTS=$PWD/.ssh-known-hosts/esxi_known_hosts
# Optional SHA256 fingerprint verified out of band before accepting a new SSH key.
ESXI_HOST_FINGERPRINT=
# TLS verification is enabled by default. Set a trusted local CA bundle if needed.
ESXI_CA_BUNDLE=
# ESXI_INSECURE_TLS=1 is a temporary, explicit, lab-only exception.
