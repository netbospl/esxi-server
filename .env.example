# Example ESXi environment configuration.
# Copy this file to .env or configure these values in your shell/secret manager.
# Do not commit real hostnames, passwords, tokens, private IPs, or SSH key material.

ESXI_HOST=your-esxi-host.example.com
ESXI_USER=root
ESXI_PASS=replace-with-secret-manager-or-local-env-only
ESXI_SSH_KEY=/path/to/private/key
